cursor-style = block
cursor-style-blink = false
background = 000000
font-size = 15
font-feature = -liga
# font-thicken = true
alpha-blending = linear

# Key bindings for tab navigation
keybind = cmd+left=previous_tab
keybind = cmd+right=next_tab
keybind = ctrl+left=previous_tab
keybind = ctrl+right=next_tab

# Key bindings for moving tabs left/right
keybind = cmd+shift+left=move_tab:-1
keybind = cmd+shift+right=move_tab:1
keybind = ctrl+shift+left=move_tab:-1
keybind = ctrl+shift+right=move_tab:1
macos-option-as-alt = true

keybind = all:cmd+h=goto_split:left
keybind = all:cmd+l=goto_split:right
keybind = all:cmd+j=goto_split:down
keybind = all:cmd+k=goto_split:up

# Resize splits
keybind = cmd+shift+h=resize_split:left,15
keybind = cmd+shift+l=resize_split:right,15
keybind = cmd+shift+j=resize_split:down,15
keybind = cmd+shift+k=resize_split:up,15

# Equalize all splits to equal size
keybind = cmd+equal=equalize_splits

# Toggle current split to full screen (zoom)
keybind = cmd+shift+f=toggle_split_zoom

# Make split borders more visible
split-divider-color = #666666

# Make inactive splits dimmer to highlight active one
unfocused-split-opacity = 0.7


# Fix Shift+Enter to create newline instead of submitting
keybind = shift+enter=text:\n

# Fix for Ctrl key with non-US keyboard layouts
macos-non-native-fullscreen = false
window-decoration = true

# Disable cursor feature to keep block cursor, enable everything else
shell-integration-features = no-cursor

# Note: Custom clickable file paths are not yet fully implemented in Ghostty
# URLs are clickable by default with cmd+click (macOS) or ctrl+click (Linux)

# Fix shift+click selection behavior
mouse-shift-capture = never

# Ensure new tabs/panes start from the same directory as the current one
window-inherit-working-directory = true

auto-update-channel = tip
